<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#7C0909" />
            <stroke android:width="1dp" android:color="#FFF0A6" />
            <corners android:radius="7dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#3D3D3D" android:endColor="#141414" />
            <stroke android:width="1dp" android:color="#B88B12" />
            <corners android:radius="7dp" />
        </shape>
    </item>
</selector>
