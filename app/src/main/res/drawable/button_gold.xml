<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#C49A00" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:angle="270" android:startColor="#FFF59D" android:endColor="#FFC107" />
            <stroke android:width="1dp" android:color="#8D6E00" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
