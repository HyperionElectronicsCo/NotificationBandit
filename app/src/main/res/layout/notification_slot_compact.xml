<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="54dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="7dp"
    android:paddingRight="4dp"
    android:background="@drawable/machine_background">

    <ImageView
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="Slot machine icon" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingLeft="7dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOTIFICATION BANDIT"
            android:textStyle="bold"
            android:textColor="#FFD54F"
            android:textSize="12sp" />

        <TextView
            android:id="@id/compact_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Credits 100 • Bet 1"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <Button
        android:id="@id/compact_bet_button"
        android:layout_width="46dp"
        android:layout_height="34dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="BET 1"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:textSize="9sp"
        android:background="@drawable/bet_button" />

    <ImageButton
        android:id="@id/compact_lever_button"
        android:layout_width="42dp"
        android:layout_height="48dp"
        android:padding="0dp"
        android:scaleType="fitCenter"
        android:src="@drawable/lever_up"
        android:background="@drawable/lever_touch_background"
        android:contentDescription="Pull lever to spin" />
</LinearLayout>
