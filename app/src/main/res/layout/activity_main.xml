<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/activity_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="22dp">

        <ImageView
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Slot machine icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOTIFICATION BANDIT"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:textSize="26sp"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/panel_background"
            android:layout_marginTop="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This one-arm bandit lives in your notification shade. Expand it, choose a 1, 2, 5 or 10-credit bet, then pull the red side lever. The reels animate and stop one at a time."
                android:textColor="@color/white"
                android:textSize="17sp"
                android:lineSpacingExtra="3dp" />

            <TextView
                android:id="@id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: checking…"
                android:textColor="@color/gold"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="18dp" />

            <Button
                android:id="@id/start_button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="START / RESTORE NOTIFICATION"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/button_gold"
                android:layout_marginTop="18dp" />

            <Button
                android:id="@id/reset_button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="RESET CREDITS TO 100"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_red"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payouts scale with the selected bet. Three 7s pay 50× the bet, three BARs pay 25×, and any matching pair pays 2×. Entertainment only — no real money, purchases or cash prizes. Android can still remove it after Force Stop, notification permission removal, or aggressive battery optimisation."
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginTop="18dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
